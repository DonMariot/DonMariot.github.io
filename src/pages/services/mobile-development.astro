---
import BaseLayout from "../../layouts/BaseLayout.astro";

const SEO = {
  title: "Mobile App Development | Don Mariot R.",
  description:
    "Professional mobile app development services for iOS and Android, optimized for performance, UX, and scalability.",
  image: "/og-mobile-dev.jpg",
  breadcrumbs: [
    { name: "Home", href: "/" },
    { name: "Services", href: "/services" },
    { name: "Mobile Development", href: "/services/mobile-development" },
  ],
};
---

<BaseLayout {...SEO}>
  <section class="max-w-3xl mx-auto py-16">

    <h1 class="text-3xl font-bold mb-6">Mobile Application Development</h1>

    <p class="opacity-80 mb-8">
      I develop high-performance mobile applications for iOS and Android, delivering seamless user experiences and scalable architecture.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">Cross-Platform Development</h2>
    <p class="opacity-80">
      Using modern frameworks to build apps that work across multiple platforms with optimal performance.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">Performance & UX</h2>
    <p class="opacity-80">
      Focused on speed, intuitive design, and smooth interactions to enhance user engagement.
    </p>

    <div class="mt-12">
      <a
        href="/#contact"
        class="inline-block px-6 py-3 bg-white text-black rounded-lg font-medium hover:opacity-90 transition"
      >
        Start Your Mobile Project
      </a>
    </div>

  </section>
</BaseLayout>