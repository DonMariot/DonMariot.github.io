---
import SeoPage from "../../layouts/SeoPage.astro";

const SEO = {
  title: "Web Development Services | High-Performance & SEO-Optimized",
  description:
    "Professional web development services using Astro and React. Fast, scalable, and SEO-optimized websites built for performance and conversion.",
  image: "/og-web-dev.jpg",
};
---

<SeoPage {...SEO}>
  <section class="max-w-3xl mx-auto py-16">

    <h1 class="text-3xl font-bold mb-6">
      Web Development Services
    </h1>

    <p class="mb-8 opacity-80">
      I build fast, scalable, and SEO-optimized web applications designed to deliver performance and measurable business results.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">
      High-Performance Websites
    </h2>
    <p class="opacity-80">
      Every website is engineered for speed, accessibility, and clean architecture using modern frameworks like Astro and React.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">
      Built-in SEO Optimization
    </h2>
    <p class="opacity-80">
      From structure to metadata, each project is designed to rank efficiently on search engines with best-in-class SEO practices.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">
      Technologies
    </h2>
    <p class="opacity-80">
      Astro, React, Typescript, Tailwind CSS, Node.js, Next.js, Nest.js, modern deployment pipelines.
    </p>

    <div class="mt-12">
      <a
        href="/#contact"
        class="inline-block px-6 py-3 bg-white text-black rounded-lg font-medium hover:opacity-90 transition"
      >
        Start a Project
      </a>
    </div>

  </section>
</SeoPage>