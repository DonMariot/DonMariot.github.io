---
import SeoPage from "../../layouts/SeoPage.astro";

const SEO = {
  title: "Workflow Automation Services | Optimize & Scale Your Business",
  description:
    "Automate your business processes with scalable workflows. Save time, reduce errors, and increase efficiency using modern automation systems.",
  image: "/og-automation.jpg",
};
---

<SeoPage {...SEO}>
  <section class="max-w-3xl mx-auto py-16">

    <h1 class="text-3xl font-bold mb-6">
      Workflow Automation
    </h1>

    <p class="mb-8 opacity-80">
      I design and implement automated workflows that streamline operations, reduce manual work, and improve business efficiency.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">
      Process Automation
    </h2>
    <p class="opacity-80">
      Automate repetitive tasks such as data entry, notifications, and system integrations to eliminate bottlenecks.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">
      System Integration
    </h2>
    <p class="opacity-80">
      Connect your tools, APIs, and platforms into a unified system that works seamlessly together.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">
      Scalable Architecture
    </h2>
    <p class="opacity-80">
      Build automation systems that scale with your business and adapt to growth without breaking.
    </p>

    <div class="mt-12">
      <a
        href="/#contact"
        class="inline-block px-6 py-3 bg-white text-black rounded-lg font-medium hover:opacity-90 transition"
      >
        Automate Your Business
      </a>
    </div>

  </section>
</SeoPage>