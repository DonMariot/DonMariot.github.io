---
import BaseLayout from "../../layouts/BaseLayout.astro";

const SEO = {
  title: "Architecture & Design Services | Don Mariot R.",
  description:
    "Professional digital architecture and system design services, creating scalable, efficient, and maintainable solutions for your business.",
  image: "/og-architecture.jpg",
  breadcrumbs: [
    { name: "Home", href: "/" },
    { name: "Services", href: "/services" },
    { name: "Architecture & Design", href: "/services/architecture-design" },
  ],
};
---

<BaseLayout {...SEO}>
  <section class="max-w-3xl mx-auto py-16">

    <h1 class="text-3xl font-bold mb-6">Architecture & Design Services</h1>

    <p class="opacity-80 mb-8">
      I provide digital architecture and system design services to ensure your applications and workflows are scalable, efficient, and maintainable.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">System Architecture</h2>
    <p class="opacity-80">
      Designing robust system structures with clean architecture principles for long-term scalability.
    </p>

    <h2 class="text-2xl font-semibold mt-10 mb-4">Workflow & Integration</h2>
    <p class="opacity-80">
      Integrating systems and workflows to optimize business operations and reduce complexity.
    </p>

    <div class="mt-12">
      <a
        href="/#contact"
        class="inline-block px-6 py-3 bg-white text-black rounded-lg font-medium hover:opacity-90 transition"
      >
        Start Your Architecture Project
      </a>
    </div>

  </section>
</BaseLayout>