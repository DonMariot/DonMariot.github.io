---
import BaseLayout from "../../layouts/BaseLayout.astro";

const SEO = {
  title: "Case Study — Exemple de Projet | Don Mariot R.",
  description:
    "A detailed case study showcasing a digital solution designed and implemented by Don Mariot R. focusing on performance, scalability, and SEO.",
  image: "/og-case-study.jpg",
  breadcrumbs: [
    { name: "Home", href: "/" },
    { name: "Case Studies", href: "/case-studies" },
    { name: "Projet Exemple", href: "/case-studies/projetct-1" },
  ],
};
---

<BaseLayout {...SEO}>
  <section class="max-w-3xl mx-auto py-16">

    <h1 class="text-3xl font-bold mb-6">Case Study — Projet Exemple</h1>

    <p class="opacity-80 mb-8">
      This project demonstrates a fully optimized digital solution focusing on high performance, scalability, and SEO best practices.
    </p>

    <div>
      <a
        href="/case-studies"
        class="inline-block px-6 py-3 bg-white text-black rounded-lg font-medium hover:opacity-90 transition"
      >
        Back to Case Studies
      </a>
    </div>

  </section>
</BaseLayout>