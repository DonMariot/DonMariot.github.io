---
import SeoPage from "../../layouts/SeoPage.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const sortedPosts = posts
  .filter((post) => !(post.data.draft ?? false))
  .sort((a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
---

<SeoPage
  title="Blog — Insights on SEO, Automation & Systems"
  description="Explore articles on SEO, system architecture, workflow automation, and high-performance web development."
>
  <section class="max-w-3xl mx-auto py-16">
    <h1 class="text-3xl font-bold mb-10">Blog</h1>
    <ul class="space-y-6">
      {sortedPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="block group">
            <h2 class="text-xl font-semibold group-hover:underline">
              {post.data.title}
            </h2>
            <p class="opacity-70 text-sm mt-1">{post.data.description}</p>
            <p class="opacity-50 text-xs mt-1">
              {new Date(post.data.date).toLocaleDateString()}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</SeoPage>