---
const { i18nKey, imageSrc } = Astro.props;
---

<div class="flex flex-row items-center px-4 py-2 bg-black/30 border border-white/10 hover:border-white/20 transition rounded-lg gap-4 w-full">

  <div class="flex-1 min-w-0 flex flex-col justify-between">
    <h3
      class="text-base md:text-lg font-semibold text-white wrap-break-word sm:truncate"
      data-i18n={`${i18nKey}.title`}
    ></h3>

    <p
      class="text-sm text-white/70 leading-snug wrap-break-word sm:truncate"
      data-i18n={`${i18nKey}.description`}
    ></p>
  </div>
 
  {imageSrc && (
    <div class="shrink-0 w-16 sm:w-1/4">
      <div class="h-18 md:h-18 rounded-lg overflow-hidden">
        <img
          src={imageSrc}
          data-i18n-alt={`${i18nKey}.title`}
          class="w-full h-full object-contain opacity-95 object-center rounded-2xl"
        />
      </div>
    </div>
  )}
</div>