---
const { title, description } = Astro.props
---

<div
  class="
  border
  border-white/10
  rounded-xl
  p-4
  bg-white/5
  hover:border-white/20
  transition
  text-center
  backdrop-blur-sm
"
>

  <h3
    class="text-xl font-semibold mb-3 text-white"
    data-i18n={title}
  ></h3>

  <p
    class="text-white/70 leading-relaxed"
    data-i18n={description}
  ></p>

</div>