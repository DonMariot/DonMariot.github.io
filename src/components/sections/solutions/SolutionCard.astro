---
import Card from "../../ui/Card.astro"
import { Icon } from "astro-icon/components"

const { title, description, icon } = Astro.props
---

<Card
  class="
    p-6
    border
    border-white/10
    hover:border-white
    transition
    backdrop-blur-sm
    hover:cursor-pointer
  "
>
  <div class="relative h-full hover:cursor-pointer">

    <div class="absolute top-0 right-0 text-white/40">
      <Icon name={icon} class="w-6 h-6" />
    </div>

    <h3
      class="text-xl font-semibold mb-3 text-white"
      data-i18n={title}
    ></h3>

    <p
      class="text-white/70 leading-relaxed"
      data-i18n={description}
    ></p>

  </div>
</Card>