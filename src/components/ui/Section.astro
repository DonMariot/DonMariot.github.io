---
interface Props {
  id?: string;
  center?: boolean;
  class?: string;
}
const { id, center = true, class: extraClass = "" } = Astro.props;
---

<section
  id={id}
  class={`
    relative flex w-full
    min-h-svh
    ${center ? "justify-center text-center" : ""}
    px-6 lg:px-8
    py-20 md:py-28
    max-w-full mx-auto
    before:absolute before:top-0 before:left-0 before:w-full before:h-px
    before:bg-linear-to-r before:from-transparent before:via-white/10 before:to-transparent
    ${extraClass}
  `}
>
  <slot />
</section>