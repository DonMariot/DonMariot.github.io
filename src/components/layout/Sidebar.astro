---
import { Icon } from "astro-icon/components";
import { navigation } from "../../lib/navigation"

const { title = "" } = Astro.props;
---

<nav class="
    fixed top-0 left-0 h-screen w-16
    bg-black/20 backdrop-blur-md border-r border-white/20
    flex flex-col justify-between p-3
    z-50
    transform transition-transform duration-300
    -translate-x-full md:translate-x-0
  "
>
  <div class="text-center text-gray-300 text-lg mb-6">{title}</div>

  <ul class="flex flex-col gap-6 items-center text-gray-500 ">
    {navigation.map(item => {
      const colorClass = "text-white";
      return (
        <li>
          <a
            href={item.href}
            class={`nav-link flex flex-col items-center transition-all duration-200 font-normal hover:scale-110 hover:text-white`}
          >
            <Icon name={item.icon} class={`w-5 h-5 mb-1 transition-all duration-300 ${colorClass} `} />
            <span class="text-xs" data-i18n={item.label}></span>
          </a>
        </li>
      )
    })}
  </ul>

  <div class="flex justify-center mt-auto relative">
    <button id="profile-button" class="block w-9 h-9 rounded-full overflow-hidden border border-black hover:scale-105 transition hover:cursor-pointer">
      <img src="/images/profil.webp" alt="Profile" class="w-full h-full object-cover" loading="lazy" />
    </button>

    <div
      id="about-popup"
      class="absolute left-full ml-8 bottom-1 w-72 
      bg-linear-to-b from-zinc-900/95 to-black
      backdrop-blur-xl
      border border-white/10
      rounded-2xl
      p-5
      text-sm
      text-gray-300
      shadow-[0_20px_60px_rgba(0,0,0,0.6)]
      hidden
      transition-all duration-300
      hover:cursor-pointer
      hover:border-white/20"
    >
      <div class="flex items-center justify-between text-white pb-3 border-b border-white/10 mb-4">
        <span class="font-semibold tracking-wide text-sm text-white" data-i18n="popup.title"></span>
        <img src="/images/next-step.png" alt="info" class="w-7 h-7 opacity-80" loading="lazy"/>
      </div>

      <p class="text-gray-300 leading-relaxed text-[13px]" data-i18n="popup.line1"></p>

      <p class="text-gray-400 leading-relaxed text-[13px] mt-2"data-i18n="popup.line2"></p>

      <a href="#contact" 
        data-i18n="popup.cta"
        class="mt-4 inline-flex items-center text-[12px] font-medium text-blue-400 hover:text-blue-300 transition-colors">

        <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
      </a>

      <div class="mt-5 pt-3 border-t border-white/10 text-[10px] text-gray-500 flex justify-center text-center tracking-wide">
        &lt; © Powered by DM — 2026 /&gt;
      </div>
    </div>
  </div>
</nav>

<script src="/src/scripts/profilePopup.ts"></script>